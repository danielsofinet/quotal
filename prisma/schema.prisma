generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String      @id @default(cuid())
  firebaseUid          String      @unique
  email                String      @unique
  name                 String?
  inboxAddress         String      @unique
  plan                 String      @default("free")
  stripeCustomerId     String?     @unique
  stripeSubscriptionId String?     @unique
  planExpiresAt        DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  projects             Project[]
  inboxItems           InboxItem[]
}

model Project {
  id        String   @id @default(cuid())
  name      String
  emailSlug String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotes    Quote[]

  @@unique([userId, emailSlug])
}

model InboxItem {
  id                  String   @id @default(cuid())
  userId              String
  fromEmail           String
  fromName            String?
  subject             String?
  textBody            String?
  attachments         Json?
  assignedToProjectId String?
  assignedToProject   String?
  assignedAt          DateTime?
  createdAt           DateTime @default(now())
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model Quote {
  id               String           @id @default(cuid())
  projectId        String
  vendorName       String?
  fileName         String?
  originalFileUrl  String?
  rawText          String?
  currency         String?
  dateReceived     DateTime         @default(now())
  paymentTerms     String?
  deliveryDays     Int?
  notes            String[]
  grandTotal       Float?
  processingStatus ProcessingStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lineItems        LineItem[]
  fees             Fee[]
}

model LineItem {
  id            String  @id @default(cuid())
  quoteId       String
  name          String
  rawName       String
  canonicalName String?
  variantNote   String?
  unitPrice     Float
  quantity      Float
  unit          String
  subtotal      Float
  quote         Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("template-download")
  createdAt DateTime @default(now())
}

model Fee {
  id       String  @id @default(cuid())
  quoteId  String
  name     String
  amount   Float
  isHidden Boolean @default(false)
  quote    Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}
